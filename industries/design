<script>
/* Captures utm_source from URL, persists in localStorage, fills hidden form input. */
(function () {
  function setByName(name, value) {
    document.querySelectorAll('input[name="' + name + '"]').forEach(function (el) {
      el.value = value || '';
    });
  }

  var params = new URLSearchParams(window.location.search);
  var val = params.get('utm_source') || '';

  if (val) {
    try { localStorage.setItem('utm_source', val); } catch (e) {}
  } else {
    try { val = localStorage.getItem('utm_source') || ''; } catch (e) { val = ''; }
  }

  setByName('utm_source', val);
})();
</script>

<script>
/* Gets GA4 client_id (browser identifier) via gtag and fills hidden form inputs. */
(function () {
  var MEASUREMENT_ID = 'G-R7QDP0M1EZ';

  function setByName(name, value) {
    document.querySelectorAll('input[name="' + name + '"]').forEach(function (el) {
      el.value = value || '';
    });
  }

  if (typeof window.gtag !== 'function') {
   	return; 
  }

  gtag('get', MEASUREMENT_ID, 'client_id', function (clientId) {
    setByName('ga_client_id', clientId);
  });
})();
</script>

<script>
/* Detects user country via IP geolocation (ipapi.co) and fills the hidden "country" form input. */
(function () {
  function setByName(name, value) {
    document.querySelectorAll('input[name="' + name + '"]').forEach(function (el) {
      el.value = value || '';
    });
  }

  fetch('https://ipapi.co/json/')
    .then(function (r) { return r.json(); })
    .then(function (data) {
      var country = (data && data.country_name) ? data.country_name : '';
      setByName('country', country);
    })
    .catch(function () {});
})();
</script>

<script>
/* Stores ONLY the first EXTERNAL referrer (different domain) and fills hidden input [name="referrer"]. */
(function () {
  function setByName(name, value) {
    document.querySelectorAll('input[name="' + name + '"]').forEach(function (el) {
      el.value = value || '';
    });
  }

  var STORAGE_KEY = 'first_external_referrer';
  var currentHost = window.location.hostname;

  function safeHost(url) {
    try { return (new URL(url)).hostname; } catch (e) { return ''; }
  }

  var ref = document.referrer || '';
  var refHost = ref ? safeHost(ref) : '';

  if (ref && refHost && refHost !== currentHost) {
    try {
      if (!localStorage.getItem(STORAGE_KEY)) {
        localStorage.setItem(STORAGE_KEY, ref);
      }
    } catch (e) {}
  }

  var saved = '';
  try { saved = localStorage.getItem(STORAGE_KEY) || ''; } catch (e) { saved = ''; }

  setByName('referrer', saved);
})();
</script>

<style>
/* Hide all tags by default to prevent flash */
[fs-cmsfilter-element="tag-template"] {
  display: none !important;
}

/* Only show tags that are marked as allowed (industry tags) */
[fs-cmsfilter-element="tag-template"].show-tag {
  display: flex !important;
}
</style>

<script>
const observeTags = () => {
  const tagContainer = document.querySelector('[fs-cmsfilter-element="tags"]');
  if (!tagContainer) {
    // If container doesn't exist yet, try again shortly
    setTimeout(observeTags, 100);
    return;
  }

  // Get all service labels to compare against
  const getServiceLabels = () => {
    const labels = [];
    document.querySelectorAll('.services-list [fs-cmsfilter-field="service"]').forEach(label => {
      labels.push(label.textContent.trim());
    });
    return labels;
  };

  // Check if a tag should be shown (not a service tag)
  const shouldShowTag = (tag) => {
    const tagText = tag.querySelector('[fs-cmsfilter-element="tag-text"]');
    if (!tagText) return false;
    
    const tagValue = tagText.textContent.trim();
    const serviceLabels = getServiceLabels();
    
    // If tag matches a service label, don't show it
    return !serviceLabels.includes(tagValue);
  };

  // Process existing tags
  const processExistingTags = () => {
    document.querySelectorAll('[fs-cmsfilter-element="tag-template"]').forEach(tag => {
      if (shouldShowTag(tag)) {
        tag.classList.add('show-tag');
      } else {
        tag.classList.remove('show-tag');
      }
    });
  };

  // Create observer to watch for new tags being added
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      mutation.addedNodes.forEach((node) => {
        if (node.nodeType === 1 && node.hasAttribute('fs-cmsfilter-element')) {
          if (node.getAttribute('fs-cmsfilter-element') === 'tag-template') {
            // New tag added, check if it should be shown
            if (shouldShowTag(node)) {
              node.classList.add('show-tag');
            }
          }
        }
      });
    });
  });

  // Start observing
  observer.observe(tagContainer, {
    childList: true,
    subtree: true
  });

  // Process any existing tags
  processExistingTags();
};

window.fsAttributes = window.fsAttributes || [];
window.fsAttributes.push([
  'cmsfilter',
  (filterInstances) => {
    const [filterInstance] = filterInstances;
    
    // Start observing tags
    observeTags();
    
    // Re-process tags whenever filters change
    filterInstance.listInstance.on('renderitems', () => {
      setTimeout(() => {
        document.querySelectorAll('[fs-cmsfilter-element="tag-template"]').forEach(tag => {
          const tagText = tag.querySelector('[fs-cmsfilter-element="tag-text"]');
          if (!tagText) return;
          
          const tagValue = tagText.textContent.trim();
          const serviceLabels = [];
          document.querySelectorAll('.services-list [fs-cmsfilter-field="service"]').forEach(label => {
            serviceLabels.push(label.textContent.trim());
          });
          
          if (serviceLabels.includes(tagValue)) {
            tag.classList.remove('show-tag');
          } else {
            tag.classList.add('show-tag');
          }
        });
      }, 0);
    });
  },
]);
</script>






<script>
document.addEventListener("DOMContentLoaded", function () {
  const dropdownToggle = document.querySelector(".fs-selectcustom_dropdown-toggle");
  const targetSection = document.querySelector(".scroll-anchor");

  if (!dropdownToggle || !targetSection) return;

  dropdownToggle.addEventListener("click", function () {
    // Only run on mobile
    if (window.innerWidth <= 991) {
      targetSection.scrollIntoView({
        behavior: "smooth",
        block: "start"
      });
    }
  });
});
</script></body></html>