<script>
/* Captures utm_source from URL, persists in localStorage, fills hidden form input. */
(function () {
  function setByName(name, value) {
    document.querySelectorAll('input[name="' + name + '"]').forEach(function (el) {
      el.value = value || '';
    });
  }

  var params = new URLSearchParams(window.location.search);
  var val = params.get('utm_source') || '';

  if (val) {
    try { localStorage.setItem('utm_source', val); } catch (e) {}
  } else {
    try { val = localStorage.getItem('utm_source') || ''; } catch (e) { val = ''; }
  }

  setByName('utm_source', val);
})();
</script>

<script>
/* Gets GA4 client_id (browser identifier) via gtag and fills hidden form inputs. */
(function () {
  var MEASUREMENT_ID = 'G-R7QDP0M1EZ';

  function setByName(name, value) {
    document.querySelectorAll('input[name="' + name + '"]').forEach(function (el) {
      el.value = value || '';
    });
  }

  if (typeof window.gtag !== 'function') {
   	return; 
  }

  gtag('get', MEASUREMENT_ID, 'client_id', function (clientId) {
    setByName('ga_client_id', clientId);
  });
})();
</script>

<script>
/* Detects user country via IP geolocation (ipapi.co) and fills the hidden "country" form input. */
(function () {
  function setByName(name, value) {
    document.querySelectorAll('input[name="' + name + '"]').forEach(function (el) {
      el.value = value || '';
    });
  }

  fetch('https://ipapi.co/json/')
    .then(function (r) { return r.json(); })
    .then(function (data) {
      var country = (data && data.country_name) ? data.country_name : '';
      setByName('country', country);
    })
    .catch(function () {});
})();
</script>

<script>
/* Stores ONLY the first EXTERNAL referrer (different domain) and fills hidden input [name="referrer"]. */
(function () {
  function setByName(name, value) {
    document.querySelectorAll('input[name="' + name + '"]').forEach(function (el) {
      el.value = value || '';
    });
  }

  var STORAGE_KEY = 'first_external_referrer';
  var currentHost = window.location.hostname;

  function safeHost(url) {
    try { return (new URL(url)).hostname; } catch (e) { return ''; }
  }

  var ref = document.referrer || '';
  var refHost = ref ? safeHost(ref) : '';

  if (ref && refHost && refHost !== currentHost) {
    try {
      if (!localStorage.getItem(STORAGE_KEY)) {
        localStorage.setItem(STORAGE_KEY, ref);
      }
    } catch (e) {}
  }

  var saved = '';
  try { saved = localStorage.getItem(STORAGE_KEY) || ''; } catch (e) { saved = ''; }

  setByName('referrer', saved);
})();
</script>
<script>
function getCoords(elem) {
    const box = elem.getBoundingClientRect();

    const body = document.body;
    const docEl = document.documentElement;

    const scrollTop = window.pageYOffset || docEl.scrollTop || body.scrollTop;
    const clientTop = docEl.clientTop || body.clientTop || 0;

    const top = box.top + scrollTop - clientTop;
    const bottom = box.bottom + scrollTop - clientTop;

    return { 
        top: Math.round(top), 
        bottom: Math.round(bottom) 
    }
}

document.addEventListener("DOMContentLoaded", function() {
    // Reference GSAP and ScrollTrigger from the window object
    const gsap = window.gsap;
    const ScrollTrigger = window.ScrollTrigger;

    // Register ScrollTrigger plugin with GSAP
    gsap.registerPlugin(ScrollTrigger);

    // Select all service items using their common class
    const serviceItems = gsap.utils.toArray(".service-item");
    // Select all actual video elements nested inside the .services-video wrappers
    const videos = gsap.utils.toArray(".services-video-new video");
    // Select the mask video container (the div with overflow: hidden)
    const videoMask = document.querySelector(".mask-video");
    // Container that contains all of the videos
    const videoMaskTrack = document.querySelector(".mask-track");

    // Basic check to ensure all required elements are found
    if (serviceItems.length === 0 || videos.length === 0 || !videoMask) {
        console.warn("GSAP Scroll Animation: Required elements not found. Animation aborted.");
        return;
    }

    // Set initial z-index and y position for videos
    // Video 1 starts at 0% and plays.
    // Videos 2, 3, 4 start at 25% and are paused.
    videos.forEach((video, index) => {
        video.style.zIndex = videos.length - index; // video-1 highest z-index, video-4 lowest

        if (index === 0) {
            gsap.set(video, { y: 0 });
        } else {
            gsap.set(video, { yPercent: -50 });
        }
    });

    // Loop through each service item to create scroll-triggered animations.
    // We start from the second service item (index 1) because it triggers
    // the transition from video-1 to video-2, and so on.
    for (let i = 1; i < 4; i++) {
        const triggerElement = serviceItems[i].querySelector("h2"); // The service item that triggers this specific video transition

        // Get section document position
        const coords = () => getCoords(triggerElement);
        const videoHeight = () => videoMask.clientHeight;
        const videoOffset = () => (window.innerHeight - videoHeight()) / 2;

        // Create a ScrollTrigger for each service item
        ScrollTrigger.create({
            trigger: triggerElement,
            start: () => coords().top - window.innerHeight + videoOffset(),
            end: () => `+=${videoHeight()}`,
            scrub: true,
            //markers: true,
            onUpdate: ({ progress }) => {
                // Move track to show next video
                gsap.to(videoMaskTrack, {
                    yPercent: - ((i - 1) * 25 + 25 * progress),
                    duration: 0.01,
                    ease: "none"
                });

                // Parallax
                gsap.to(videos[i], {
                    yPercent: -50 + 50 * progress,
                    duration: 0.01,
                    ease: "none"
                });
            }
        });
    }

    // IMPORTANT: Force ScrollTrigger to refresh on window resize.
    // This will re-evaluate the 'start' and 'end' functions for each ScrollTrigger.
    window.addEventListener("resize", () => {
        console.log("refresh");

        ScrollTrigger.refresh();
    });
});
